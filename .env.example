CHATIMAGE_API_KEY=replace_with_your_key
# The image API authenticates via the bare key in the Authorization header.
# The key is NOT sent in the URL query string by default (that would leak it
# into upstream access logs). Set CHATIMAGE_IMAGE_KEY_IN_QUERY=1 only if the
# upstream ever rejects header auth and requires the key as a ?key= parameter.
CHATIMAGE_IMAGE_KEY_IN_QUERY=0
CHATIMAGE_TEXT_API_KEY=replace_with_your_text_key
CHATIMAGE_TEXT_BASE_URL=https://api.xiaomimimo.com/v1
CHATIMAGE_TEXT_ENDPOINT=
CHATIMAGE_TEXT_MODEL=mimo-v2.5-pro
CHATIMAGE_TEXT_FALLBACK_MODEL=mimo-v2.5
CHATIMAGE_TEXT_FALLBACK_ON_5XX=1
CHATIMAGE_TEXT_REQUEST_FORMAT=openai-chat
CHATIMAGE_TEXT_MAX_COMPLETION_TOKENS=
CHATIMAGE_TEXT_TEMPERATURE=1.0
CHATIMAGE_TEXT_TOP_P=0.95
CHATIMAGE_TEXT_JSON_RESPONSE_FORMAT=prompt
CHATIMAGE_TEXT_THINKING_TYPE=disabled
CHATIMAGE_VISUAL_QA_MODE=limited
CHATIMAGE_VISUAL_QA_MAX_RETRIES=1
CHATIMAGE_IMAGE_MODEL=GPT-Image-2
# The current upstream image gateway rejects free-form 16:9 sizes such as
# 1600x900. Keep the API request on a supported bitmap size; the prompt still
# asks for a centered 16:9 composition when needed.
CHATIMAGE_IMAGE_API_SIZE=1024x1024
# local-ocr | locateanything | mimo-vision | remote
CHATIMAGE_VISION_MODE=local-ocr
# Optional: when CHATIMAGE_VISION_MODE=locateanything, use MiMo vision to fill boxes LocateAnything misses.
CHATIMAGE_VISION_FALLBACK_MODE=
# For CHATIMAGE_VISION_MODE=mimo-vision, these default to CHATIMAGE_TEXT_BASE_URL/chat/completions and model mimo-v2.5.
CHATIMAGE_VISION_BASE_URL=https://api.xiaomimimo.com/v1
CHATIMAGE_VISION_ENDPOINT=
CHATIMAGE_VISION_API_KEY=
CHATIMAGE_VISION_MODEL=
CHATIMAGE_VISION_AUTH_MODE=bearer
CHATIMAGE_VISION_REQUEST_FORMAT=openai-chat
CHATIMAGE_LOCAL_OCR_PYTHON=python
CHATIMAGE_LOCAL_OCR_TIMEOUT_MS=30000
CHATIMAGE_LOCAL_OCR_MAX_IMAGE_BYTES=8388608
CHATIMAGE_LOCATEANYTHING_LICENSE_ACK=
CHATIMAGE_LOCATEANYTHING_PYTHON=python
CHATIMAGE_LOCATEANYTHING_MODEL=nvidia/LocateAnything-3B
CHATIMAGE_LOCATEANYTHING_DEVICE=cuda
CHATIMAGE_LOCATEANYTHING_TIMEOUT_MS=120000
CHATIMAGE_LOCATEANYTHING_MAX_NEW_TOKENS=
CHATIMAGE_LOCATEANYTHING_MAX_IMAGE_SIDE=960
CHATIMAGE_LOCATEANYTHING_GENERATION_MODE=hybrid

# Optional SAM3 mask refinement after LocateAnything/local-ocr/planned boxes.
# Keep disabled unless you have accepted the model terms and installed the sam3 conda env.
CHATIMAGE_SAM3_ENABLED=
CHATIMAGE_SAM3_LICENSE_ACK=
CHATIMAGE_SAM3_PYTHON=C:\Users\YOUR_NAME\miniconda3\envs\sam3\python.exe
CHATIMAGE_SAM3_CHECKPOINT=C:\Users\YOUR_NAME\.cache\modelscope\hub\models\facebook\sam3\sam3.pt
CHATIMAGE_SAM3_DEVICE=cuda
CHATIMAGE_SAM3_TIMEOUT_MS=120000
CHATIMAGE_PORT=5178
CHATIMAGE_API_REQUEST_TIMEOUT_MS=120000
CHATIMAGE_IMAGE_POLL_ATTEMPTS=90
CHATIMAGE_IMAGE_POLL_INITIAL_DELAY_MS=1200
CHATIMAGE_IMAGE_POLL_DELAY_MS=2000
CHATIMAGE_MAX_UPSTREAM_REQUESTS=4

# --- Advanced / optional (sensible defaults; uncomment to override) ---
# Reject a generated result when any hotspot fails strict visual grounding
# (no primary locator + SAM mask). Default true. Set false to keep results with
# planned/sam3-refined-planned fallbacks (e.g. for batch experiments).
# CHATIMAGE_STRICT_VISUAL_ALIGNMENT=true
# Local SQLite database path. Default tmp/chatimage.sqlite.
# CHATIMAGE_DATABASE_PATH=tmp/chatimage.sqlite
# Static directory served by the backend (set to dist after npm run build).
# CHATIMAGE_STATIC_DIR=
# Max JSON request body in bytes (raise if saving large mask/alignment payloads).
# CHATIMAGE_MAX_JSON_BODY_BYTES=33554432
# Cache generated images on disk to avoid re-fetching. Default enabled.
# CHATIMAGE_IMAGE_CACHE_ENABLED=true
